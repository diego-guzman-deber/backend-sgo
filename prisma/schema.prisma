generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model customer {
  id         BigInt    @id @default(autoincrement())
  externalId String?   @unique @map("external_id")
  name       String
  phone      String?
  email      String?
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt   DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  contracts   contract[]
  salesOrders sales_order[]
  workOrders  work_order[]
}

model agent {
  id         BigInt    @id @default(autoincrement())
  externalId String?   @unique @map("external_id")
  name       String
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt   DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  salesOrders sales_order[]
}

model media_channel {
  id         BigInt    @id @default(autoincrement())
  externalId String?   @unique @map("external_id")
  name       String
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt   DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  products   product[]
  workOrders work_order[]
}

model product {
  id             BigInt    @id @default(autoincrement())
  externalId     String?   @unique @map("external_id")
  name           String
  mediaChannelId BigInt?   @map("media_channel_id")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt       DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  mediaChannel     media_channel?     @relation(fields: [mediaChannelId], references: [id])
  workOrders       work_order[]
  workOrderDetails work_order_detail[]
}

model contract {
  id              BigInt    @id @default(autoincrement())
  externalId      String?   @unique @map("external_id")
  date            DateTime? @db.Date
  title           String?
  content         String?
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  totalAmount     Decimal?  @map("total_amount") @db.Decimal(12, 2)
  ownConsumption  Boolean?  @map("own_consumption")
  customerId      BigInt?   @map("customer_id")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt        DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  customer   customer?    @relation(fields: [customerId], references: [id])
  workOrders work_order[]
}

model sales_order {
  id         BigInt    @id @default(autoincrement())
  externalId String?   @unique @map("external_id")
  customerId BigInt?   @map("customer_id")
  agentId    BigInt?   @map("agent_id")
  year       Int?
  month      Int?
  total      Decimal?  @db.Decimal(12, 2)
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt   DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  customer   customer?    @relation(fields: [customerId], references: [id])
  agent      agent?       @relation(fields: [agentId], references: [id])
  workOrders work_order[]
}

model work_order {
  id             BigInt    @id @default(autoincrement())
  externalId     String?   @unique @map("external_id")
  customerId     BigInt?   @map("customer_id")
  mediaChannelId BigInt?   @map("media_channel_id")
  productId      BigInt?   @map("product_id")
  description    String?
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  registeredAt   DateTime? @default(now()) @map("registered_at") @db.Timestamptz(6)
  totalAmount    Decimal?  @map("total_amount") @db.Decimal(12, 2)
  source         String?
  isActive       Boolean   @default(true) @map("is_active")
  status         String?   @db.VarChar(20)
  contractId     BigInt?   @map("contract_id")
  salesOrderId   BigInt?   @map("sales_order_id")
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt       DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  customer     customer?         @relation(fields: [customerId], references: [id])
  mediaChannel media_channel?    @relation(fields: [mediaChannelId], references: [id])
  product      product?          @relation(fields: [productId], references: [id])
  contract     contract?         @relation(fields: [contractId], references: [id])
  salesOrder   sales_order?      @relation(fields: [salesOrderId], references: [id])
  details      work_order_detail[]
}

model work_order_detail {
  id            BigInt    @id @default(autoincrement())
  externalId    String?   @unique @map("external_id")
  workOrderId   BigInt?   @map("work_order_id")
  productId     BigInt?   @map("product_id")
  isActive      Boolean   @default(true) @map("is_active")
  status        String?   @db.VarChar(20)
  scheduledAt   DateTime? @map("scheduled_at") @db.Timestamptz(6)
  rescheduledAt DateTime? @map("rescheduled_at") @db.Timestamptz(6)
  executedAt    DateTime? @map("executed_at") @db.Timestamptz(6)
  amount        Decimal?  @db.Decimal(12, 2)
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  syncedAt      DateTime? @default(now()) @map("synced_at") @db.Timestamptz(6)

  workOrder work_order? @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  product   product?    @relation(fields: [productId], references: [id])
}

model sync_history {
  id               BigInt    @id @default(autoincrement())
  entity           String    @db.VarChar(50)
  syncStartedAt    DateTime  @default(now()) @map("sync_started_at") @db.Timestamptz(6)
  syncFinishedAt   DateTime? @map("sync_finished_at") @db.Timestamptz(6)
  processedRecords Int?      @default(0) @map("processed_records")
  dataRangeFrom    DateTime? @map("data_range_from") @db.Timestamptz(6)
  dataRangeTo      DateTime? @map("data_range_to") @db.Timestamptz(6)
  status           String?   @db.VarChar(20)
  errorMessage     String?   @map("error_message")
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
}
